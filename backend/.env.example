# ─── Server Configuration ─────────────────────────────────
PORT=5000
NODE_ENV=production
FRONTEND_URL=https://your-frontend-domain.vercel.app

# ─── Database Configuration ───────────────────────────────
# Connection string for AWS RDS PostgreSQL
DATABASE_URL=postgresql://username:password@rds-endpoint.amazonaws.com:5432/praxiredb?sslmode=require

# ─── Authentication Secret ────────────────────────────────
# Secret key to sign JWTs (generate a strong random string)
JWT_SECRET=your_jwt_secret_key_here

# ─── Mail Server Configuration (Nodemailer/SMTP) ─────────
# Gmail account details for sending automated system mails
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
ADMIN_EMAIL=superadmin@praxire.com

# ─── Google Drive API (Resume Cloud Storage) ──────────────
# Google Service Account and Folder credentials
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id
GOOGLE_CLIENT_EMAIL=your-service-account@your-project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC7...\n-----END PRIVATE KEY-----\n"
